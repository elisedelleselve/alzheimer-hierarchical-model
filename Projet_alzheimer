{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"datasetVersion","sourceId":5962731,"datasetId":3419493,"databundleVersionId":6040418}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# Project: Hierarchical Classification for Alzheimer's Disease Detection\n\n**Context & Acknowledgment:**\nThis project aims to implement a hierarchical classification. The initial data processing and baseline architecture are inspired by Ashis Kumar Pati's notebook, adapted here to address our new research question: **Is a two-step hierarchical classification approach more effective at detecting the earliest signs of Alzheimer's disease?**\n\n**Step 1:** Binary Classification (Healthy vs. Sick)","metadata":{}},{"cell_type":"code","source":"# Importing necessary libraries \n\nimport numpy as np\nimport pandas as pd\nimport keras\nimport matplotlib.pyplot as plt\nimport re\nimport os\nimport random\nimport tensorflow as tf\nimport plotly.express as px\nimport cv2\nimport seaborn as sns\n\n\nfrom keras.models import Sequential\nfrom PIL import Image\nfrom keras.layers import Conv2D,Flatten,Dense,Dropout,BatchNormalization,MaxPooling2D, GlobalAveragePooling2D\nfrom sklearn.preprocessing import OneHotEncoder, label_binarize\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.utils.class_weight import compute_class_weight\nfrom sklearn.metrics import auc, average_precision_score, confusion_matrix, roc_auc_score, f1_score, confusion_matrix, precision_recall_fscore_support, classification_report\nfrom tensorflow.keras.applications import EfficientNetB0, EfficientNetV2B1\nfrom tensorflow.keras.preprocessing.image import ImageDataGenerator\nfrom tensorflow.keras import layers, models\nfrom tensorflow.keras.utils import to_categorical\nfrom tensorflow.keras.callbacks import EarlyStopping\nfrom tensorflow.keras.optimizers import Adam\nfrom tensorflow.keras.models import clone_model\nfrom tensorflow.keras.models import Sequential\nfrom matplotlib.colors import LogNorm, LinearSegmentedColormap\nfrom PIL import Image\nfrom scipy.stats import skew\nfrom tqdm import tqdm\n\nprint(\"Libraries imported successfully!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:32:56.595616Z","iopub.execute_input":"2026-04-07T12:32:56.595918Z","iopub.status.idle":"2026-04-07T12:33:22.581665Z","shell.execute_reply.started":"2026-04-07T12:32:56.595894Z","shell.execute_reply":"2026-04-07T12:33:22.581033Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 1. Data Organization (Full Dataset & Binary Grouping)\nInstead of loading images into RAM, creation of a DataFrame containing the paths of all ~86,000 images. Grouping the labels into a binary classification: \"Healthy\" vs \"Sick\".","metadata":{}},{"cell_type":"code","source":"\ndata_dir = '/kaggle/input/datasets/ninadaithal/imagesoasis/Data'\n\nfilepaths = []\nlabels = []\n\nprint(\"Scanning directories for images...\")\nfor folder in os.listdir(data_dir):\n    folder_path = os.path.join(data_dir, folder)\n    if os.path.isdir(folder_path):\n        for file in os.listdir(folder_path):\n            if file.endswith('.jpg'):\n                filepaths.append(os.path.join(folder_path, file))\n                if folder == 'Non Demented':\n                    labels.append('Healthy')\n                else:\n                    labels.append('Sick')\n\n# Create the initial DataFrame\ndf = pd.DataFrame({'path': filepaths, 'label': labels})\n\nsick_df = df[df['label'] == 'Sick']\n# On tire au sort autant de sains qu'il y a de malades\nhealthy_df = df[df['label'] == 'Healthy'].sample(n=len(sick_df), random_state=42)\n# On fusionne et on mélange\nbalanced_df = pd.concat([sick_df, healthy_df]).sample(frac=1, random_state=42).reset_index(drop=True)\n\n# Split into Train and Test with the balanced data\ntrain_df, test_df = train_test_split(balanced_df, test_size=0.2, random_state=42, stratify=balanced_df['label'])\n\nprint(f\"Dataset ready\")\nprint(f\"Training set: {len(train_df)} images.\")\nprint(f\"Testing set: {len(test_df)} images.\")\nprint(\"\\nLabel distribution in Training Set:\")\nprint(train_df['label'].value_counts())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:33:22.582996Z","iopub.execute_input":"2026-04-07T12:33:22.583428Z","iopub.status.idle":"2026-04-07T12:33:24.012326Z","shell.execute_reply.started":"2026-04-07T12:33:22.583405Z","shell.execute_reply":"2026-04-07T12:33:24.011569Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 2. Image Data Generators & Class Weights\nUse of `ImageDataGenerator` to stream images directly from the disk in batches. This prevents RAM saturation. Computation of `class_weights` to handle the severe dataset imbalance and penalize the model more if it misses a \"Sick\" patient.","metadata":{}},{"cell_type":"code","source":"\ndatagen = ImageDataGenerator(rescale=1./255)\n\n# Train Generator \ntrain_generator = datagen.flow_from_dataframe(\n    dataframe=train_df,\n    x_col='path',\n    y_col='label',\n    target_size=(128, 128),\n    batch_size=32,\n    class_mode='binary',\n    classes=['Healthy', 'Sick'],\n    validate_filenames=False \n)\n\n# Test Generator\ntest_generator = datagen.flow_from_dataframe(\n    dataframe=test_df,\n    x_col='path',\n    y_col='label',\n    target_size=(128, 128),\n    batch_size=32,\n    class_mode='binary',\n    classes=['Healthy', 'Sick'],\n    shuffle=False,\n    validate_filenames=False \n)\n\n# Compute Class Weights to fix the imbalance\nweights = compute_class_weight(\n    class_weight='balanced',\n    classes=np.unique(train_generator.classes),\n    y=train_generator.classes\n)\nclass_weights = dict(enumerate(weights))\nprint(f\"Class weights applied: {class_weights}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:33:24.013310Z","iopub.execute_input":"2026-04-07T12:33:24.014021Z","iopub.status.idle":"2026-04-07T12:33:24.106311Z","shell.execute_reply.started":"2026-04-07T12:33:24.013995Z","shell.execute_reply":"2026-04-07T12:33:24.105728Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 3. Modeling: EfficientNetB0 (Fine-Tuning)\nUse of a pre-trained EfficientNetB0, frozen except for the last 20 layers, allowing it to adapt to medical textures. We use a single output neuron with a `sigmoid` activation for binary classification.","metadata":{}},{"cell_type":"code","source":"\nbase_model = EfficientNetB0(weights='imagenet', include_top=False, input_shape=(128, 128, 3))\n\n# Unfreeze the last 20 layers\nbase_model.trainable = True\nfor layer in base_model.layers[:-20]: \n    layer.trainable = False\n\nmodel = Sequential([\n    base_model,\n    GlobalAveragePooling2D(),\n    BatchNormalization(),\n    Dropout(0.5),\n    Dense(1, activation='sigmoid') # Binary output\n])\n\n# Low learning rate for fine-tuning\nmodel.compile(optimizer=Adam(learning_rate=1e-4),\n              loss='binary_crossentropy',\n              metrics=['accuracy'])\n\nprint(\"Model built successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:33:24.107980Z","iopub.execute_input":"2026-04-07T12:33:24.108475Z","iopub.status.idle":"2026-04-07T12:33:28.405469Z","shell.execute_reply.started":"2026-04-07T12:33:24.108451Z","shell.execute_reply":"2026-04-07T12:33:28.404752Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 4. Model Training\nTraining the model using the generators and the computed class weights to handle the imbalance.","metadata":{}},{"cell_type":"code","source":"\nearly_stopping = EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True)\n\nhistory = model.fit(\n    train_generator,\n    epochs=10, \n    validation_data=test_generator, \n    callbacks=[early_stopping]\n)\n\nprint(\"Training complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:33:28.406353Z","iopub.execute_input":"2026-04-07T12:33:28.406557Z","iopub.status.idle":"2026-04-07T12:48:34.919615Z","shell.execute_reply.started":"2026-04-07T12:33:28.406537Z","shell.execute_reply":"2026-04-07T12:48:34.918750Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 5. Model Evaluation & Visualizations\n\nTo fully understand the model's robust performance, we look beyond a single accuracy score. We visualize the learning process, evaluate the detailed metrics on the unseen test set, and analyze the model's confidence.\n\n### 5.1. Learning Curves\nPlotting the training and validation accuracy and loss to confirm that the Early Stopping mechanism worked correctly and that the model did not fall back into severe overfitting.","metadata":{}},{"cell_type":"code","source":"\nprint(\"Generating Learning Curves\")\n\nacc = history.history['accuracy']\nval_acc = history.history['val_accuracy']\nloss = history.history['loss']\nval_loss = history.history['val_loss']\nepochs_range = range(1, len(acc) + 1)\n\nplt.figure(figsize=(14, 5))\n\nplt.subplot(1, 2, 1)\nplt.plot(epochs_range, acc, label='Training Accuracy', marker='o')\nplt.plot(epochs_range, val_acc, label='Validation Accuracy', marker='o')\nplt.title('Training and Validation Accuracy')\nplt.xlabel('Epochs')\nplt.ylabel('Accuracy')\nplt.legend()\nplt.grid(True)\n\nplt.subplot(1, 2, 2)\nplt.plot(epochs_range, loss, label='Training Loss', marker='o')\nplt.plot(epochs_range, val_loss, label='Validation Loss', marker='o')\nplt.title('Training and Validation Loss')\nplt.xlabel('Epochs')\nplt.ylabel('Loss')\nplt.legend()\nplt.grid(True)\n\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:48:34.920903Z","iopub.execute_input":"2026-04-07T12:48:34.921186Z","iopub.status.idle":"2026-04-07T12:48:35.260167Z","shell.execute_reply.started":"2026-04-07T12:48:34.921159Z","shell.execute_reply":"2026-04-07T12:48:35.259531Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 5.2. Confusion Matrix & Classification Report\nEvaluation of the model on the ~17,000 images of the test set. The **Confusion Matrix** shows exactly how many Sick patients were correctly identified (True Positives) versus how many were missed (False Negatives). The Classification Report provides the final Precision, Recall, and F1-Score.","metadata":{}},{"cell_type":"code","source":"\nprint(\"Running predictions on the Test set\")\n# 1. On demande au modèle de prédire les probabilités (entre 0 et 1)\npredictions = model.predict(test_generator)\n\n# 2. On transforme les probabilités en choix fermés (> 50% = Malade)\ny_pred = (predictions > 0.5).astype(int).reshape(-1)\n\n# 3. On récupère les vraies réponses depuis le générateur\ny_true = test_generator.classes\n\n# 4. On dessine la Matrice\ncm = confusion_matrix(y_true, y_pred)\nplt.figure(figsize=(8, 6))\nsns.heatmap(cm, annot=True, fmt='d', cmap='Blues', \n            xticklabels=['Healthy (0)', 'Sick (1)'], \n            yticklabels=['Healthy (0)', 'Sick (1)'])\nplt.title('Final Confusion Matrix: Healthy vs Sick')\nplt.xlabel('Predicted Label')\nplt.ylabel('True Label')\nplt.show()\n\nprint(\"\\nFinal Classification Report:\\n\")\nprint(classification_report(y_true, y_pred, target_names=['Healthy', 'Sick']))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:48:35.261084Z","iopub.execute_input":"2026-04-07T12:48:35.261332Z","iopub.status.idle":"2026-04-07T12:49:09.818113Z","shell.execute_reply.started":"2026-04-07T12:48:35.261309Z","shell.execute_reply":"2026-04-07T12:49:09.817470Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"### 5.3. Prediction Confidence Analysis\nUse a boxplot to visualize the distribution of the predicted probabilities. This shows how \"confident\" the model is. A clear separation between the probabilities assigned to True Healthy patients and True Sick patients indicates a highly discriminative model.","metadata":{}},{"cell_type":"code","source":"\nprint(\"Generating Prediction Probability Boxplot\")\n\nresults_df = pd.DataFrame({\n    'True Label': ['Sick' if label == 1 else 'Healthy' for label in y_true],\n    'Predicted Probability of being Sick': predictions.reshape(-1)\n})\n\nplt.figure(figsize=(8, 6))\nsns.boxplot(data=results_df, x='True Label', y='Predicted Probability of being Sick', palette='Set2')\nplt.axhline(0.5, color='red', linestyle='--', label='Decision Threshold (50%)')\nplt.title('Boxplot of Model Confidence (Probabilities)')\nplt.legend()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T12:49:09.819182Z","iopub.execute_input":"2026-04-07T12:49:09.819494Z","iopub.status.idle":"2026-04-07T12:49:10.003477Z","shell.execute_reply.started":"2026-04-07T12:49:09.819467Z","shell.execute_reply":"2026-04-07T12:49:10.002811Z"}},"outputs":[],"execution_count":null}]}