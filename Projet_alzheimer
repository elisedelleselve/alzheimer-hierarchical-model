{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":5962731,"datasetId":3419493,"databundleVersionId":6040418}],"dockerImageVersionId":31328,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"markdown","source":"# Project: Hierarchical Classification for Alzheimer's Disease Detection\n\n**Context & Acknowledgment:**\nThis project aims to implement a hierarchical classification. The initial data processing and baseline architecture are inspired by Ashis Kumar Pati's notebook, adapted here to address our new research question: **Is a two-step hierarchical classification approach more effective at detecting the earliest signs of Alzheimer's disease?**\n\n**Step 1:** Binary Classification (Healthy vs. Sick)","metadata":{}},{"cell_type":"code","source":"# Importing necessary libraries \n\nimport numpy as np\nimport pandas as pd\nimport keras\nimport matplotlib.pyplot as plt\nimport re\nimport os\nimport random\nimport tensorflow as tf\nimport plotly.express as px\nimport cv2\nimport seaborn as sns\n\n\nfrom keras.models import Sequential\nfrom PIL import Image\nfrom keras.layers import Conv2D,Flatten,Dense,Dropout,BatchNormalization,MaxPooling2D, GlobalAveragePooling2D\nfrom sklearn.preprocessing import OneHotEncoder, label_binarize\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.utils.class_weight import compute_class_weight\nfrom sklearn.metrics import auc, average_precision_score, confusion_matrix, roc_auc_score, f1_score, confusion_matrix, precision_recall_fscore_support, classification_report\nfrom tensorflow.keras.applications import EfficientNetB0, EfficientNetV2B1\nfrom tensorflow.keras.preprocessing.image import ImageDataGenerator\nfrom tensorflow.keras import layers, models\nfrom tensorflow.keras.utils import to_categorical\nfrom tensorflow.keras.callbacks import EarlyStopping\nfrom tensorflow.keras.optimizers import Adam\nfrom tensorflow.keras.models import clone_model\nfrom tensorflow.keras.models import Sequential\nfrom matplotlib.colors import LogNorm, LinearSegmentedColormap\nfrom PIL import Image\nfrom scipy.stats import skew\nfrom tqdm import tqdm\n\nprint(\"Libraries imported successfully!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T16:30:05.393326Z","iopub.execute_input":"2026-04-07T16:30:05.393865Z","iopub.status.idle":"2026-04-07T16:30:47.316326Z","shell.execute_reply.started":"2026-04-07T16:30:05.393831Z","shell.execute_reply":"2026-04-07T16:30:47.315495Z"}},"outputs":[{"name":"stderr","text":"2026-04-07 16:30:09.247163: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1775579409.652027      55 cuda_dnn.cc:8579] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\nE0000 00:00:1775579409.764534      55 cuda_blas.cc:1407] Unable to register cuBLAS factory: Attempting to register factory for plugin cuBLAS when one has already been registered\nW0000 00:00:1775579410.779862      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1775579410.779900      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1775579410.779903      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1775579410.779905      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\n","output_type":"stream"},{"name":"stdout","text":"Libraries imported successfully!\n","output_type":"stream"}],"execution_count":1},{"cell_type":"markdown","source":"## 1. Data Organization (Full Dataset & Binary Grouping)\nInstead of loading images into RAM, creation of a DataFrame containing the paths of all ~86,000 images. Grouping the labels into a binary classification: \"Healthy\" vs \"Sick\".","metadata":{}},{"cell_type":"code","source":"\ndata_dir = '/kaggle/input/datasets/ninadaithal/imagesoasis/Data'\n\nfilepaths = []\nlabels = []\n\nprint(\"Scanning directories for images...\")\nfor folder in os.listdir(data_dir):\n    folder_path = os.path.join(data_dir, folder)\n    if os.path.isdir(folder_path):\n        for file in os.listdir(folder_path):\n            if file.endswith('.jpg'):\n                filepaths.append(os.path.join(folder_path, file))\n                if folder == 'Non Demented':\n                    labels.append('Healthy')\n                else:\n                    labels.append('Sick')\n\n# Create the initial DataFrame\ndf = pd.DataFrame({'path': filepaths, 'label': labels})\n\nsick_df = df[df['label'] == 'Sick']\n# On tire au sort autant de sains qu'il y a de malades\nhealthy_df = df[df['label'] == 'Healthy'].sample(n=len(sick_df), random_state=42)\n# On fusionne et on mélange\nbalanced_df = pd.concat([sick_df, healthy_df]).sample(frac=1, random_state=42).reset_index(drop=True)\n\n# Split into Train and Test with the balanced data\ntrain_df, test_df = train_test_split(balanced_df, test_size=0.2, random_state=42, stratify=balanced_df['label'])\n\nprint(f\"Dataset ready\")\nprint(f\"Training set: {len(train_df)} images.\")\nprint(f\"Testing set: {len(test_df)} images.\")\nprint(\"\\nLabel distribution in Training Set:\")\nprint(train_df['label'].value_counts())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T16:30:47.317762Z","iopub.execute_input":"2026-04-07T16:30:47.318305Z","iopub.status.idle":"2026-04-07T16:30:48.727317Z","shell.execute_reply.started":"2026-04-07T16:30:47.318280Z","shell.execute_reply":"2026-04-07T16:30:48.726525Z"}},"outputs":[{"name":"stdout","text":"Scanning directories for images...\nDataset ready\nTraining set: 30744 images.\nTesting set: 7686 images.\n\nLabel distribution in Training Set:\nlabel\nSick       15372\nHealthy    15372\nName: count, dtype: int64\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"## 2. Image Data Generators & Class Weights\nUse of `ImageDataGenerator` to stream images directly from the disk in batches. This prevents RAM saturation. Computation of `class_weights` to handle the severe dataset imbalance and penalize the model more if it misses a \"Sick\" patient.","metadata":{}},{"cell_type":"code","source":"\ndatagen = ImageDataGenerator(rescale=1./255)\n\n# Train Generator \ntrain_generator = datagen.flow_from_dataframe(\n    dataframe=train_df,\n    x_col='path',\n    y_col='label',\n    target_size=(128, 128),\n    batch_size=32,\n    class_mode='binary',\n    classes=['Healthy', 'Sick'],\n    validate_filenames=False \n)\n\n# Test Generator\ntest_generator = datagen.flow_from_dataframe(\n    dataframe=test_df,\n    x_col='path',\n    y_col='label',\n    target_size=(128, 128),\n    batch_size=32,\n    class_mode='binary',\n    classes=['Healthy', 'Sick'],\n    shuffle=False,\n    validate_filenames=False \n)\n\n# Compute Class Weights to fix the imbalance\nweights = compute_class_weight(\n    class_weight='balanced',\n    classes=np.unique(train_generator.classes),\n    y=train_generator.classes\n)\nclass_weights = dict(enumerate(weights))\nprint(f\"Class weights applied: {class_weights}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T16:30:48.728293Z","iopub.execute_input":"2026-04-07T16:30:48.728646Z","iopub.status.idle":"2026-04-07T16:30:48.820142Z","shell.execute_reply.started":"2026-04-07T16:30:48.728619Z","shell.execute_reply":"2026-04-07T16:30:48.819563Z"}},"outputs":[{"name":"stdout","text":"Found 30744 non-validated image filenames belonging to 2 classes.\nFound 7686 non-validated image filenames belonging to 2 classes.\nClass weights applied: {0: np.float64(1.0), 1: np.float64(1.0)}\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"## 3. Modeling: EfficientNetB0 (Fine-Tuning)\nUse of a pre-trained EfficientNetB0, frozen except for the last 20 layers, allowing it to adapt to medical textures. We use a single output neuron with a `sigmoid` activation for binary classification.","metadata":{}},{"cell_type":"code","source":"\nbase_model = EfficientNetB0(weights='imagenet', include_top=False, input_shape=(128, 128, 3))\n\n# Unfreeze the last 20 layers\nbase_model.trainable = True\nfor layer in base_model.layers[:-20]: \n    layer.trainable = False\n\nmodel = Sequential([\n    base_model,\n    GlobalAveragePooling2D(),\n    BatchNormalization(),\n    Dropout(0.5),\n    Dense(1, activation='sigmoid') # Binary output\n])\n\n# Low learning rate for fine-tuning\nmodel.compile(optimizer=Adam(learning_rate=1e-4),\n              loss='binary_crossentropy',\n              metrics=['accuracy'])\n\nprint(\"Model built successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-07T16:30:48.820961Z","iopub.execute_input":"2026-04-07T16:30:48.821176Z","iopub.status.idle":"2026-04-07T16:30:54.501829Z","shell.execute_reply.started":"2026-04-07T16:30:48.821156Z","shell.execute_reply":"2026-04-07T16:30:54.501152Z"}},"outputs":[{"name":"stderr","text":"I0000 00:00:1775579451.291842      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 137