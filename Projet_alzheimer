rics\")\n\n# 1. Ask the AI to predict the stages for the testing set\npredictions_stage = model_stage.predict(test_gen_stage)\n\n# Unlike binary classification, we now get 3 probabilities per image (like [0.1, 0.8, 0.1])\n# np.argmax picks the index of the highest probability (like index 1)\ny_pred_stage = np.argmax(predictions_stage, axis=1)\n\n# Extract the true diagnostic stages\ny_true_stage = test_gen_stage.classes\n\n# Extract the names of the stages (mild, moderate, very mild) mapping directly from Keras\nclass_labels = list(test_gen_stage.class_indices.keys())\n\n# Setup Figure\nfig, axes = plt.subplots(1, 2, figsize=(15, 6))\n\n# Plot 1: Learning curves\naxes[0].plot(history_stage.history['accuracy'], label='Train Acc', marker='o')\naxes[0].plot(history_stage.history['val_accuracy'], label='Val Acc', marker='o')\naxes[0].set_title('Phase 2: Learning Curves')\naxes[0].set_xlabel('Epochs')\naxes[0].set_ylabel('Accuracy')\naxes[0].legend()\naxes[0].grid(True)\n\n# Plot 2: Confusion matrix\ncm_stage = confusion_matrix(y_true_stage, y_pred_stage)\nsns.heatmap(cm_stage, annot=True, fmt='d', cmap='Purples', ax=axes[1],\n            xticklabels=class_labels, yticklabels=class_labels)\naxes[1].set_title('Phase 2 Confusion Matrix: Dementia Stages')\naxes[1].set_xlabel('Predicted Stage')\naxes[1].set_ylabel('True Stage')\nplt.xticks(rotation=45)\n\nplt.tight_layout()\nplt.show()\n\n# Print detailed text report (recall, precision, F1-score for each of the 3 stages)\nprint(\"\\nPhase 2 classification report:\\n\")\nprint(classification_report(y_true_stage, y_pred_stage, target_names=class_labels))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T20:48:38.230656Z","iopub.execute_input":"2026-04-20T20:48:38.231051Z","iopub.status.idle":"2026-04-20T20:48:39.499035Z","shell.execute_reply.started":"2026-04-20T20:48:38.231021Z","shell.execute_reply":"2026-04-20T20:48:39.498128Z"}},"outputs":[{"name":"stdout","text":"Generating phase 2 evaluation metrics\n\u001b[1m10/10\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 65ms/step\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x600 with 3 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\nPhase 2 classification report:\n\n                    precision    recall  f1-score   support\n\n     Mild Dementia       0.83      0.90      0.86        97\n Moderate Dementia       0.98      1.00      0.99        98\nVery mild Dementia       0.90      0.81      0.85        98\n\n          accuracy                           0.90       293\n         macro avg       0.90      0.90      0.90       293\n      weighted avg       0.90      0.90      0.90       293\n\n","output_type":"stream"}],"execution_count":12},{"cell_type":"markdown","source":"## 5. Model Explainability (Grad-CAM)\nIt is not enough for an AI to simply output a prediction; in a medical case, clinicians need to understand *why* that decision was made. To achieve this, implementation of **Grad-CAM** (Gradient-weighted Class Activation Mapping). \n\nThis technique generates a visual heat map over the MRI scans, highlighting the exact anatomical regions (in red and yellow) that most strongly influenced our EfficientNet model's diagnosis. This adds a crucial layer of transparency, ensuring the model relies on true biological markers (like ventricular enlargement) rather than background noise.","metadata":{}},{"cell_type":"code","source":"# Function to generate the Gradient-weighted Class Activation Mapping (Grad-CAM)\ndef make_gradcam_heatmap(img_array, model):\n    # 1. extract the base pre-trained model (EfficientNet) which is the first layer of the \"model_stage\"\n    base_model = model.layers[0] # EfficientNet\n\n    # tf.GradientTape =  TensorFlow API that records operations for automatic differentiation (tracking gradients)\n    with tf.GradientTape() as tape:\n        # Convert the numpy image array into a TensorFlow tensor\n        img_tensor = tf.convert_to_tensor(img_array)\n        \n        # Pass the image through EfficientNet to get the final convolutional feature maps\n        conv_outputs = base_model(img_tensor, training=False)\n        # Tell the tape to track these specific feature maps so we can compute gradients against them later\n        tape.watch(conv_outputs)\n        \n        # Pass the outputs through the remaining layers (GlobalAveragePooling, BatchNorm and Dropout)\n        x = conv_outputs\n        for layer in model.layers[1:-1]: # Stop jsut before the very last dense prediction layer\n            x = layer(x, training=False)\n            \n        # Apply the final classification layer manually, without the softmax activation.\n        # because softmax forces probabilities to sum to 1, which distorts the raw importance scores\n        last_layer = model.layers[-1]\n        logits = tf.matmul(x, last_layer.kernel)\n        if last_layer.bias is not None:\n            logits += last_layer.bias\n\n        # Identify which class (stage) the AI is actually predicting\n        pred_index = tf.argmax(logits[0])\n        class_channel = logits[:, pred_index] # Isolate the raw score for the winning class\n\n    # 2. Calculate the gradients of the winning class with respect to the convolutional feature maps\n    # question: \"Which parts of the image had the biggest mathematical impact on the decision?\"\n    grads = tape.gradient(class_channel, conv_outputs)\n    \n    # Average the gradients spatially (reduces the 3D map to a 1D vector of weights)\n    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))\n\n    # Multiply each channel in the feature map by \"how important\" it is (its gradient weight)\n    conv_outputs = conv_outputs[0]\n    heatmap = conv_outputs @ pooled_grads[..., tf.newaxis]\n    heatmap = tf.squeeze(heatmap)\n    \n    # Normalize\n    heatmap = tf.maximum(heatmap, 0)\n    max_heat = tf.math.reduce_max(heatmap)\n    if max_heat > 0:\n        heatmap /= max_heat \n\n    # Focused Grad-CAM\n    # Keep only the top 50% most important pixels, erase the rest (background noise), focuses only on the core diagnostic zones\n    heatmap = tf.where(heatmap > 0.5, heatmap, 0.0)\n        \n    return heatmap.numpy()\n\n# Randomly select 3 patient images from the test set for display\nsample_indices = random.sample(range(len(test_stage_df)), 3)\nfig, axes = plt.subplots(3, 3, figsize=(15, 12))\n\nfor row, idx in enumerate(sample_indices):\n    # Fetch image path and its true medical stage\n    img_path = test_stage_df.iloc[idx]['path']\n    true_label = test_stage_df.iloc[idx]['stage']\n\n    # Load and format the image for the model (128x128 pixels, added batch dimension)\n    img = tf.keras.preprocessing.image.load_img(img_path, target_size=(128, 128))\n    img_array = tf.keras.preprocessing.image.img_to_array(img)\n    img_array_batch = np.expand_dims(img_array, axis=0)\n\n    # 1. Generate the raw Grad-CAM heatmap using the function\n    heatmap = make_gradcam_heatmap(img_array_batch, model_stage)\n\n    # 2. Get the actual prediction label for the plot title\n    preds = model_stage.predict(img_array_batch, verbose=0)\n    pred_class_idx = np.argmax(preds[0])\n    pred_label = class_labels[pred_class_idx]\n\n    # 3. Superimpose the heatmap on the original MRI\n    # and resize the tiny heatmap to match the original image size (128x128)\n    heatmap_resized = cv2.resize(heatmap, (img_array.shape[1], img_array.shape[0]))\n    \n    # We apply a slight Gaussian blur to smooth the cut edges\n    heatmap_resized = cv2.GaussianBlur(heatmap_resized, (15, 15), 0)\n\n    # Convert heatmap values to 8-bit integers (0-255) for color mapping\n    heatmap_resized = np.uint8(255 * heatmap_resized)\n\n    # Apply the \"jet\" colormap (blue=low attention, red=high attention)\n    jet = plt.get_cmap(\"jet\")\n    jet_colors = jet(np.arange(256))[:, :3]\n    jet_heatmap = jet_colors[heatmap_resized]\n    \n    # Erase color where heatmap is zero to keep MRI visible\n    mask = heatmap_resized > 0\n    superimposed_img = img_array / 255.0\n    superimposed_img[mask] = jet_heatmap[mask] * 0.6 + (img_array[mask] / 255.0) * 0.4\n    superimposed_img = np.clip(superimposed_img, 0, 1)\n\n    axes[row, 0].imshow(img_array / 255.0)\n    axes[row, 0].set_title(f\"Original MRI\\nTrue Stage: {true_label}\", fontsize=12, fontweight='bold')\n    axes[row, 0].axis('off')\n\n    axes[row, 1].imshow(heatmap_resized, cmap='jet')\n    axes[row, 1].set_title(\"AI Attention Heatmap (focused)\", fontsize=12, fontweight='bold')\n    axes[row, 1].axis('off')\n\n    axes[row, 2].imshow(superimposed_img)\n    axes[row, 2].set_title(f\"Superimposed MRI\\nPredicted Stage: {pred_label}\", fontsize=12, fontweight='bold')\n    axes[row, 2].axis('off')\n\nplt.suptitle('Grad-CAM : visualizing the core diagnostic zones', fontsize=16, fontweight='bold', y=1.02)\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T20:50:18.452909Z","iopub.execute_input":"2026-04-20T20:50:18.453702Z","iopub.status.idle":"2026-04-20T20:50:34.340402Z","shell.execute_reply.started":"2026-04-20T20:50:18.453673Z","shell.execute_reply":"2026-04-20T20:50:34.339671Z"}},"outputs":[{"name":"stderr","text":"2026-04-20 20:50:28.195179: E external/local_xla/xla/stream_executor/cuda/cuda_timer.cc:86] Delay kernel timed out: measured time has sub-optimal accuracy. There may be a missing warmup execution, please investigate in Nsight Systems.\n2026-04-20 20:50:28.330877: E external/local_xla/xla/stream_executor/cuda/cuda_timer.cc:86] Delay kernel timed out: measured time has sub-optimal accuracy. There may be a missing warmup execution, please investigate in Nsight Systems.\n2026-04-20 20:50:29.071369: E external/local_xla/xla/stream_executor/cuda/cuda_timer.cc:86] Delay kernel timed out: measured time has sub-optimal accuracy. There may be a missing warmup execution, please investigate in Nsig