e.","metadata":{}},{"cell_type":"code","source":"print(\"Generating Evaluation Metrics for Phase 1\")\n\n# 1. Predictions\npredictions = model_binary.predict(test_generator)\ny_pred = (predictions > 0.5).astype(int).reshape(-1)\ny_true = test_generator.classes\n\n# 2. Setup Figure\nfig, axes = plt.subplots(1, 3, figsize=(20, 6))\n\n#Plot 1: Learning Curves\naxes[0].plot(history_binary.history['accuracy'], label='Train Acc', marker='o')\naxes[0].plot(history_binary.history['val_accuracy'], label='Val Acc', marker='o')\naxes[0].set_title('Learning Curves (Accuracy)')\naxes[0].set_xlabel('Epochs')\naxes[0].set_ylabel('Accuracy')\naxes[0].legend()\naxes[0].grid(True)\n\n#Plot 2: Confusion Matrix\ncm = confusion_matrix(y_true, y_pred)\nsns.heatmap(cm, annot=True, fmt='d', cmap='Blues', ax=axes[1],\n            xticklabels=['Healthy (0)', 'Sick (1)'], \n            yticklabels=['Healthy (0)', 'Sick (1)'])\naxes[1].set_title('Confusion Matrix: Healthy vs Sick')\naxes[1].set_xlabel('Predicted Label')\naxes[1].set_ylabel('True Label')\n\n#Plot 3: ROC Curve\nfpr, tpr, thresholds = roc_curve(y_true, predictions)\nroc_auc = auc(fpr, tpr)\naxes[2].plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC curve (AUC = {roc_auc:.2f})')\naxes[2].plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')\naxes[2].set_xlim([0.0, 1.0])\naxes[2].set_ylim([0.0, 1.05])\naxes[2].set_xlabel('False Positive Rate')\naxes[2].set_ylabel('True Positive Rate')\naxes[2].set_title('Receiver Operating Characteristic (ROC)')\naxes[2].legend(loc=\"lower right\")\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\nClassification Report:\\n\")\nprint(classification_report(y_true, y_pred, target_names=['Healthy', 'Sick']))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T15:16:38.612602Z","iopub.execute_input":"2026-04-12T15:16:38.613296Z","iopub.status.idle":"2026-04-12T15:17:08.889366Z","shell.execute_reply.started":"2026-04-12T15:16:38.613264Z","shell.execute_reply":"2026-04-12T15:17:08.888659Z"}},"outputs":[{"name":"stdout","text":"Generating Evaluation Metrics for Phase 1\n\u001b[1m241/241\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m29s\u001b[0m 95ms/step\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 2000x600 with 4 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\nClassification Report:\n\n              precision    recall  f1-score   support\n\n     Healthy       1.00      0.98      0.99      3843\n        Sick       0.98      1.00      0.99      3843\n\n    accuracy                           0.99      7686\n   macro avg       0.99      0.99      0.99      7686\nweighted avg       0.99      0.99      0.99      7686\n\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"## 4. Phase 2: Multi-Class Classification (Disease Stage)\nNow that the model can detect the presence of Alzheimer's, building of a \"Specialist\" model. We filter the dataset to only include sick patients and attempt to classify the severity of the disease (Very Mild, Mild, Moderate). We will balance these three classes to prevent majority class bias.","metadata":{}},{"cell_type":"code","source":"print(\"Preparation of balanced dataset for Phase 2 (Sick patients only)\")\n\nsick_only_df = df[df['binary'] == 'Sick'].copy()\n\nmin_count = sick_only_df['stage'].value_counts().min()\nprint(f\"Balancing classes to {min_count} images per stage\")\n\nbalanced_stage_df = sick_only_df.groupby('stage').sample(n=min_count, random_state=42)\nbalanced_stage_df = balanced_stage_df.sample(frac=1, random_state=42).reset_index(drop=True)\n\ntrain_stage_df, test_stage_df = train_test_split(balanced_stage_df, test_size=0.2, random_state=42, stratify=balanced_stage_df['stage'])\n\ndatagen_stage = ImageDataGenerator()\n\ntrain_gen_stage = datagen_stage.flow_from_dataframe(\n    dataframe=train_stage_df, x_col='path', y_col='stage',\n    target_size=(128, 128), batch_size=32, class_mode='categorical', validate_filenames=False\n)\n\ntest_gen_stage = datagen_stage.flow_from_dataframe(\n    dataframe=test_stage_df, x_col='path', y_col='stage',\n    target_size=(128, 128), batch_size=32, class_mode='categorical', shuffle=False, validate_filenames=False\n)\n\nprint(\"\\nBuilding Phase 2 Model\")\nbase_model_stage = EfficientNetB0(weights='imagenet', include_top=False, input_shape=(128, 128, 3))\nbase_model_stage.trainable = True\nfor layer in base_model_stage.layers[:-20]: \n    layer.trainable = False\n\nmodel_stage = Sequential([\n    base_model_stage,\n    GlobalAveragePooling2D(),\n    BatchNormalization(),\n    Dropout(0.5),\n    Dense(3, activation='softmax') # 3 classes\n])\n\nmodel_stage.compile(optimizer=Adam(learning_rate=1e-4), loss='categorical_crossentropy', metrics=['accuracy'])\n\nprint(\"Starting training (Phase 2)\")\nhistory_stage = model_stage.fit(\n    train_gen_stage,\n    epochs=15, \n    validation_data=test_gen_stage,\n    callbacks=[EarlyStopping(monitor='val_loss', patience=5, restore_best_weights=True), \n               ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=3)]\n)\nprint(\"Phase 2 training complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-12T15:27:05.029106Z","iopub.execute_input":"2026-04-12T15:27:05.029431Z","iopub.status.idle":"2026-04-12T15:29:02.682820Z","shell.execute_reply.started":"2026-04-12T15:27:05.029405Z","shell.execute_reply":"2026-04-12T15:29:02.681881Z"}},"outputs":[{"name":"stdout","text":"Preparation of balanced dataset for Phase 2 (Sick patients only)\nBalancing classes to 488 images per stage...\nFound 1171 non-validated image filenames belonging to 3 classes.\nFound 293 non-validated image filenames belonging to 3 classes.\n\nBuilding Phase 2 Model...\nStarting training (Phase 2)\nEpoch 1/15\n\u001b[1m15/37\u001b[0m \u001b[32m━━━━━━━━\u001b[0m\u001b[37m━━━━━━━━━━━━\u001b[0m \u001b[1m1s\u001b[0m 80ms/step - accuracy: 0.3761 - loss: 1.9136","out