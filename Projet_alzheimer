ge_counts.values, y=stage_counts.index, ax=axes[1], palette='magma')\naxes[1].set_title('Detailed Stage Distribution', fontsize=14, fontweight='bold')\naxes[1].set_xlabel('Number of MRI Scans')\naxes[1].set_ylabel('Dementia Stage')\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-11T17:49:23.264454Z","iopub.execute_input":"2026-04-11T17:49:23.265562Z","iopub.status.idle":"2026-04-11T17:49:24.836005Z","shell.execute_reply.started":"2026-04-11T17:49:23.265529Z","shell.execute_reply":"2026-04-11T17:49:24.835281Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x600 with 2 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":2},{"cell_type":"code","source":"#VISUALIZATION 2: Sample MRI Scans\nplt.figure(figsize=(15, 10))\nunique_stages = df['stage'].unique()\n\nfor i, stage in enumerate(unique_stages):\n    # Get one random image from each stage\n    sample_img_path = df[df['stage'] == stage]['path'].iloc[0]\n    img = cv2.imread(sample_img_path)\n    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB) # OpenCV uses BGR, Matplotlib uses RGB\n    \n    plt.subplot(2, 2, i + 1)\n    plt.imshow(img)\n    plt.title(f'Stage: {stage}', fontsize=12, fontweight='bold')\n    plt.axis('off')\n\nplt.suptitle('Sample MRI Scans per Category', fontsize=16, fontweight='bold', y=1.02)\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-11T17:50:15.035332Z","iopub.execute_input":"2026-04-11T17:50:15.036053Z","iopub.status.idle":"2026-04-11T17:50:15.725837Z","shell.execute_reply.started":"2026-04-11T17:50:15.036023Z","shell.execute_reply":"2026-04-11T17:50:15.725040Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x1000 with 4 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":3},{"cell_type":"markdown","source":"## 1. Data Organization (Full Dataset & Binary Grouping)\nInstead of loading images into RAM, creation of a DataFrame containing the paths of all ~86,000 images. Grouping the labels into a binary classification: \"Healthy\" vs \"Sick\".","metadata":{}},{"cell_type":"code","source":"\ndata_dir = '/kaggle/input/datasets/kanaadlimaye/alzheimers-classification-dataset'\n\nfilepaths = []\nlabels = []\n\nprint(\"Scanning directories for images\")\nfor folder in os.listdir(data_dir):\n    folder_path = os.path.join(data_dir, folder)\n    if os.path.isdir(folder_path):\n        for file in os.listdir(folder_path):\n            if file.endswith('.jpg'):\n                filepaths.append(os.path.join(folder_path, file))\n                if folder == 'Non Demented':\n                    labels.append('Healthy')\n                else:\n                    labels.append('Sick')\n\n# Create the initial DataFrame\ndf = pd.DataFrame({'path': filepaths, 'label': labels})\n\nsick_df = df[df['label'] == 'Sick']\n# On tire au sort autant de sains qu'il y a de malades\nhealthy_df = df[df['label'] == 'Healthy'].sample(n=len(sick_df), random_state=42)\n# On fusionne et on mélange\nbalanced_df = pd.concat([sick_df, healthy_df]).sample(frac=1, random_state=42).reset_index(drop=True)\n\n# Split into Train and Test with the balanced data\ntrain_df, test_df = train_test_split(balanced_df, test_size=0.2, random_state=42, stratify=balanced_df['label'])\n\nprint(f\"Dataset ready\")\nprint(f\"Training set: {len(train_df)} images.\")\nprint(f\"Testing set: {len(test_df)} images.\")\nprint(\"\\nLabel distribution in Training Set:\")\nprint(train_df['label'].value_counts())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-11T14:12:32.756741Z","iopub.execute_input":"2026-04-11T14:12:32.757230Z","iopub.status.idle":"2026-04-11T14:12:33.930477Z","shell.execute_reply.started":"2026-04-11T14:12:32.757204Z","shell.execute_reply":"2026-04-11T14:12:33.929866Z"}},"outputs":[{"name":"stdout","text":"Scanning directories for images...\nDataset ready\nTraining set: 30744 images.\nTesting set: 7686 images.\n\nLabel distribution in Training Set:\nlabel\nSick       15372\nHealthy    15372\nName: count, dtype: int64\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"## 2. Image Data Generators & Class Weights\nUse of `ImageDataGenerator` to stream images directly from the disk in batches. This prevents RAM saturation. Computation of `class_weights` to handle the severe dataset imbalance and penalize the model more if it misses a \"Sick\" patient.","metadata":{}},{"cell_type":"code","source":"\ndatagen = ImageDataGenerator(rescale=1./255)\n\n# Train Generator \ntrain_generator = datagen.flow_from_dataframe(\n    dataframe=train_df,\n    x_col='path',\n    y_col='label',\n    target_size=(128, 128),\n    batch_size=32,\n    class_mode='binary',\n    classes=['Healthy', 'Sick'],\n    validate_filenames=False \n)\n\n# Test Generator\ntest_generator = datagen.flow_from_dataframe(\n    dataframe=test_df,\n    x_col='path',\n    y_col='label',\n    target_size=(128, 128),\n    batch_size=32,\n    class_mode='binary',\n    classes=['Healthy', 'Sick'],\n    shuffle=False,\n    validate_filenames=False \n)\n\n# Compute Class Weights to fix the imbalance\nweights = compute_class_weight(\n    class_weight='balanced',\n    classes=np.unique(train_generator.classes),\n    y=train_generator.classes\n)\nclass_weights = dict(enumerate(weights))\nprint(f\"Class weights applied: {class_weights}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-11T14:12:33.931433Z","iopub.execute_input":"2026-04-11T14:12:33.931791Z","iopub.status.idle":"2026-04-11T14:12:34.016516Z","shell.execute_reply.started":"2026-04-11T14:12:33.931767Z","shell.execute_reply":"2026-04-11T14:12:34.015947Z"}},"outputs":[{"name":"stdout","text":"Found 30744 non-validated image filenames belonging to 2 classes.\nFound 7686 non-validated image filenames belonging to 2 classes.\nClass weights applied: {0: np.float64(1.0), 1: np.float64(1.0)}\n","output_type":"stream"}],"execution_count":3},{"cell_type":"markdown","source":"## 3. Modeling: EfficientNetB0 (Fine-Tuning)\nUse of a pre-trained EfficientNetB0, frozen except for the last 20 layers, allowing it to adapt to medical textures. We use a single output neuron with a `sigmoid` activation for binary classification.","metadata":{}},{"cell_type":"code","source":"\nbase_model = EfficientNetB0(weights='imagenet', include_top=False, input_shape=(128, 128, 3))\n\n# Unfreeze the last 20 layers\nbase_model.trainable = True\nfor layer in base_model.layers[:-20]: \n    layer.trainable = False\n\nmodel = Sequential([\n    base_model,\n    GlobalAveragePooling2D(),\n    BatchNormalization(),\n    Dropout(0.5),\n    Dense(1, activation='sigmoid') # Binary output\n])\n\n# Low learning rate for fine-tuning\nmodel.compile(optimizer=Adam(learning_rate=1e-4),\n              loss='binary_crossentropy',\n              metrics=['accuracy'])\n\nprint(\"Model built successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-11T14:12:34.017292Z","iopub.execute_input":"2026-04-11T14:12:34.017499Z","iopub.status.idle":"2026-04-11T14:12:38.360162Z","shell.execute_reply.started":"2026-04-11T14:12:34.017478Z","shell.execute_reply":"2026-04-11T14:12:38.359494Z"}},"outputs":[{"name":"stderr","text":"I0000 00:00:1775916755.489451      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 13757 MB memory:  -> device: 0, name: Tesla T4, pci bus id: 0000:00:04.0, compute capability: 7.5\nI0000 00:00:1775916755.495399      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:1 with 13757 MB memory:  -> device: 1, name: Tesla T4, pci bus id: 0000:00:05.0, compute capability: 7.5\n","output_type":"stream"},{"name":"stdout","text":"Downloading data from https://storage.googleapis.com/keras-applications/efficientnetb0_notop.h5\n\u001b[1m16705208/16705208\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[