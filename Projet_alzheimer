e machine learning framework for model building\nimport plotly.express as px #Used for creating interactive plots\nimport cv2 # OpenCV library: reading, resizing, and processing MRI image pixels\nimport seaborn as sns # Statistical data visualization library built on matplotlib for nice charts\n\n# Deep Learning layers and models from Keras\nfrom keras.models import Sequential # Used to initialize a linear stack of neural network layers\nfrom PIL import Image # Python Imaging Library used for opening and manipulating image files\nfrom keras.layers import Conv2D,Flatten,Dense,Dropout,BatchNormalization,MaxPooling2D, GlobalAveragePooling2D\n\n# Conv2D: Extracts spatial features (edges, textures) from the MRI images\n# Flatten: Converts 2D/3D feature maps into a 1D vector for the final dense layers\n# Dense: Fully connected layers that output the final class predictions\n# Dropout: Randomly turns off neurons during training to prevent the model from overfitting (memorizing training data)\n# BatchNormalization: Normalizes layer inputs to speed up training and stabilize the learning process\n# MaxPooling2D: Reduces the spatial dimensions (width/height) of the image to lower computational cost\n# GlobalAveragePooling2D: Often replaces Flattening to drastically reduce parameters and prevent overfitting\n\n# Machine Learning utilities for data splitting and metrics\nfrom sklearn.preprocessing import OneHotEncoder, label_binarize # Converts categorical labels into binary matrices (zeros and ones)\nfrom sklearn.model_selection import train_test_split # Splits the dataset into training and testing subsets\nfrom sklearn.utils.class_weight import compute_class_weight # Computes weights to handle imbalanced datasets (giving more importance to rare classes)\nfrom sklearn.metrics import auc, average_precision_score, confusion_matrix, roc_auc_score, f1_score, confusion_matrix, precision_recall_fscore_support, classification_report,roc_curve, auc # Various metrics to objectively evaluate the model's medical diagnostic performance (precision, recall, false positives,..)\n\n# Advanced models and Callbacks\nfrom tensorflow.keras.applications import EfficientNetB0, EfficientNetV2B1 # State-of-the-art pre-trained models chosen for high accuracy and efficiency on images\nfrom tensorflow.keras.preprocessing.image import ImageDataGenerator # Used to load images in batches and apply real-time data augmentation (no data augmentation here)\nfrom tensorflow.keras import layers, models # Modules to customize and build the AI architecture\nfrom tensorflow.keras.utils import to_categorical # Converts integer labels to one-hot encoding (for example mild = [0,1,0], to not give 2 and think that it's the double of 1)\nfrom tensorflow.keras.callbacks import EarlyStopping, ReduceLROnPlateau\n# EarlyStopping: Halts training when validation accuracy stops improving, preventing overfitting\n# ReduceLROnPlateau: Lowers the learning rate automatically when the model gets stuck, helping it find a better mathematical minimum\nfrom tensorflow.keras.optimizers import Adam # Adaptive Moment Estimation optimizer: dynamically adjusts the learning rate for faster convergence\nfrom tensorflow.keras.models import clone_model # Used to copy model architectures (useful for cross-validation)\nfrom tensorflow.keras.models import Sequential # Initializes a \"Sequential\" AI model (a linear, step-by-step stack of layers)\nimport matplotlib.cm as cm # Colormap utilities used specifically for generating Grad-CAM heatmaps \nfrom matplotlib.colors import LogNorm, LinearSegmentedColormap # Advanced color normalization for plots\nfrom PIL import Image # Python Imaging Library, used as a backend helper to load and resize MRI images\nfrom scipy.stats import skew # Statistical function to check data distribution asymmetry\nfrom tqdm import tqdm # Provides a progress bar for loops to track processing time\n\n# Visual configuration\nsns.set_theme(style=\"whitegrid\", palette=\"muted\") # Sets a clean, professional aesthetic for all Seaborn plots\nimport warnings\nwarnings.filterwarnings('ignore') # Hides deprecation warnings to keep the output clean for the presentation\n\nprint(\"Libraries imported successfully\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T19:37:34.681520Z","iopub.execute_input":"2026-04-20T19:37:34.681807Z","iopub.status.idle":"2026-04-20T19:38:00.933045Z","shell.execute_reply.started":"2026-04-20T19:37:34.681741Z","shell.execute_reply":"2026-04-20T19:38:00.932254Z"}},"outputs":[{"name":"stderr","text":"2026-04-20 19:37:38.080117: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already been registered\nWARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nE0000 00:00:1776713858.330910      55 cuda_dnn.cc:8579] Unable to register cuDNN factory: Attempting to register factory for plugin cuDNN when one has already been registered\nE0000 00:00:1776713858.399153      55 cuda_blas.cc:1407] Unable to register cuBLAS factory: Attempting to register factory for plugin cuBLAS when one has already been registered\nW0000 00:00:1776713858.956447      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1776713858.956484      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1776713858.956489      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\nW0000 00:00:1776713858.956492      55 computation_placer.cc:177] computation placer already registered. Please check linkage and avoid linking the same target more than once.\n","output_type":"stream"},{"name":"stdout","text":"Libraries imported successfully\n","output_type":"stream"}],"execution_count":1},{"cell_type":"markdown","source":"## 2. Exploratory Data Analysis (EDA)\nBefore feeding data to the Neural Network, it is crucial to understand its distribution and visualize the MRI scans. Imbalanced datasets require special strategies like undersampling or class weighting.","metadata":{}},{"cell_type":"code","source":"# Setting the root directory where the Oasis Alzheimer's MRI dataset is stored\ndata_dir = '/kaggle/input/datasets/ninadaithal/imagesoasis/Data'\n\nfilepaths = [] # List to store the exact file path of each MRI image\nlabels = [] # List to store the specific disease stage (healthy, mild,..)\nbinary_labels = [] # List to store the binary classification target (healthy vs. sick)\n\n# Loop through each subfolder in the dataset directory\nfor folder in os.listdir(data_dir):\n    folder_path = os.path.join(data_dir, folder) # Create the full path to the subfolder\n    if os.path.isdir(folder_path): # Ensure the current item is actually a directory\n        for file in os.listdir(folder_path): # Loop through every file inside the subfolder\n            if file.endswith('.jpg'): # Only process JPEG image files to avoid reading corrupted or hidden system files\n                filepaths.append(os.path.join(folder_path, file)) # Save the image path\n                labels.append(folder) # The folder name represents the clinical class label (stage)\n                binary_labels.append('Healthy' if folder == 'Non Demented' else 'Sick') # Create binary label: 'Healthy' if the folder is \"Non Demented\", else categorize as \"Sick\"\n\n# Combine the collected lists into a structured Pandas DataFrame for easy analysis and manipulation\ndf = pd.DataFrame({'path': filepaths, 'stage': labels, 'binary': binary_labels})\n\n# Visualization 1: Data distribution \nfig, axes = plt.subplots(1, 2, figsize=(16, 6))\n\n# Pie chart for binary distribution\nbinary_counts = df['binary'].value_counts() # Count how many healthy vs sick patients exist\naxes[0].pie(binary_counts, labels=binary_counts.index, autopct='%1.1f%%', startangle=90, colors=['#66b3ff','#ff9999'], shadow=True)\naxes[0].set_title('Binary Distribution: Healthy vs Sick', fontsize=14, fontweight='bold')\n\n# Bar chart for class distribution\nstage_counts = df['stage'].value_counts().sort_values(ascending=False)\nsns.barplot(x=stage_counts.values, y=stage_counts.index, ax=axes[1], palette='magma')\naxes[1].set_title('Detailed Stage Distribution', fontsize=14, fontweight='bold')\naxes[1].set_xlabel('Number of MRI Scans')\naxes[1].set_ylabel('Dementia Stage')\n\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T19:40:11.261884Z","iopub.execute_input":"2026-04-20T19:40:11.262626Z","iopub.status.idle":"2026-04-20T19:40:12.939246Z","shell.execute_reply.started":"2026-04-20T19:40:11.262592Z","shell.execute_reply":"2026-04-20T19:40:12.938582Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1600x600 with 2 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":2},{"cell_type":"code","source":"# Visualization 2: Sample MRI Scans\nplt.figure(figsize=(15, 10))\nunique_stages = df['stage'].unique() # Extract the unique Alzheimer's stages from the dataframe\n\n# Loop through each unique stage to display one representative sample image per category\nfor i, stage in enumerate(unique_stages):\n    # Locate the first image path that matches the current loop's stage\n    sample_img_path = df[df['stage'] == stage]['path'].iloc[0]\n\n    # Read the image from the file path using OpenCV\n    img = cv2.imread(sample_img_path)\n    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB) # OpenCV uses BGR, Matplotlib uses RGB so we convert it \n    \n    plt.subplot(2, 2, i + 1)\n    plt.imshow(img)\n    plt.title(f'Stage: {stage}', fontsize=12, fontweight='bold')\n    plt.axis('off')\n\nplt.suptitle('Sample MRI Scans per Category', fontsize=16, fontweight='bold', y=1.02)\nplt.tight_layout()\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T20:05:14.763755Z","iopub.execute_input":"2026-04-20T20:05:14.764563Z","iopub.status.idle":"2026-04-20T20:05:15.471416Z","shell.execute_reply.started":"2026-04-20T20:05:14.764532Z","shell.execute_reply":"2026-04-20T20:05:15.470325Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"<Figure size 1500x1000 with 4 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":3},{"cell_type":"markdown","source":"## 3. Phase 1: Binary Classification (Healthy vs Sick)\n### 3.1. Data Preparation & Undersampling\nTo prevent our model from becoming biased towards the majority class (Healthy), we will perform **Undersampling**. We will randomly select a number of 'Healthy' images strictly equal to the number of 'Sick' images, creating a perfectly balanced 50/50 dataset.","metadata":{}},{"cell_type":"code","source":"print(\"Preparation of balanced dataset for Phase 1\")\n\n# Extract all patients labeled as 'Sick' from the main dataset\nsick_df = df[df['binary'] == 'Sick']\n\n# The healthy class is much larger. To prevent AI bias, we randomly sample \n# a number of healthy patients equal to the number of sick patients\nhealthy_df = df[df['binary'] == 'Healthy'].sample(n=len(sick_df), random_state=42) # random_state=42 ensures the random selection is the same every time we run the code\n\n# Combine both datasets to create a balanced 50/50 dataset\nbalanced_df = pd.concat([sick_df, healthy_df]).sample(frac=1, random_state=42).reset_index(drop=True)\n# .sample(frac=1) shuffles the rows completely so sick and healthy are mixed up\n# .reset_index(drop=True) cleans up the row numbers after shuffling\n\n# Split the dataset into train (80%) and test (20%) sets \n# stratify=balanced_df['binary'] guarantees the 50/50 ratio is perfectly maintained in both train and test sets\ntrain_df, test_df = train_test_split(balanced_df, test_size=0.2, random_state=42, stratify=balanced_df['binary'])\n\nprint(f\"Balanced Dataset ready. Total images: {len(balanced_df)}\")\nprint(f\"Training set: {len(train_df)} | Testing set: {len(test_df)}\")\n\n# Initialize an ImageDataGenerator to load images in batches (saves RAM)\ndatagen = ImageDataGenerator()\n\n# Load training images directly from the file paths in the dataframe\ntrain_generator = datagen.flow_from_dataframe(\n    dataframe=train_df, x_col='path', y_col='binary',\n    target_size=(128, 128), # Resize all MRIs to 128x128 pixels to match EfficientNet input requirements\n    batch_size=32, # Process images in groups of 32\n    class_mode='binary', # We are predicting 2 classes (0 or 1)\n    classes=['Healthy', 'Sick'], # Define the exact class order\n    validate_filenames=False # Speeds up loading by skipping a file-check step\n)\n\n\n# Load testing images\ntest_generator = datagen.flow_from_dataframe(\n    dataframe=test_df, x_col='path', y_col='binary',\n    target_size=(128, 128), batch_size=32, class_mode='binary', \n    classes=['Healthy', 'Sick'], \n    shuffle=False, # We don't shuffle test data, otherwise we can't match predictions to true labels later\n    validate_filenames=False\n)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T20:05:56.011837Z","iopub.execute_input":"2026-04-20T20:05:56.012944Z","iopub.status.idle":"2026-04-20T20:05:56.158395Z","shell.execute_reply.started":"2026-04-20T20:05:56.012904Z","shell.execute_reply":"2026-04-20T20:05:56.157701Z"}},"outputs":[{"name":"stdout","text":"Preparation of balanced dataset for Phase 1\nBalanced Dataset ready. Total images: 38430\nTraining set: 30744 | Testing set: 7686\nFound 30744 non-validated image filenames belonging to 2 classes.\nFound 7686 non-validated image filenames belonging to 2 classes.\n","output_type":"stream"}],"execution_count":6},{"cell_type":"markdown","source":"### 3.2. Model Architecture & Training\nWe use a pre-trained **EfficientNetB0** model, unfreezing the last 20 layers for fine-tuning on our MRI scans. The output is a single neuron with a `sigmoid` activation function. We employ `EarlyStopping` and `ReduceLROnPlateau` to optimize the training process.","metadata":{}},{"cell_type":"code","source":"print(\"Building of the Binary Classification Model\")\n\n# Load EfficientNetB0 pre-trained on millions of standard images ('imagenet')\nbase_model = EfficientNetB0(weights='imagenet', include_top=False, input_shape=(128, 128, 3))\n# include_top=False removes the original \"1000-class\" classifier so we can build our own\n\n# Fine-tuning : allow the AI to update the weights of the very last layers to specialize in medical MRIs\nbase_model.trainable = True\nfor layer in base_model.layers[:-20]: # Freeze all layers except the last 20\n    layer.trainable = False\n\n# Build our custom classification head on top of the pre-trained base\nmodel_binary = Sequential([\n    base_model, # The frozen/partially-frozen EfficientNet feature extractor\n    GlobalAveragePooling2D(), # Compresses spatial dimensions into a single 1D vector (to prevent overfitting)\n    BatchNormalization(), # Normalizes inputs to the next layer to make training faster and more stable\n    Dropout(0.5), # Randomly disables 50% of neurons during training to force the model to generalize better\n    Dense(1, activation='sigmoid') # Final decision layer : outputs a single probability between 0 and 1 (healthy vs sick)\n])\n\n# Compile the model with the Adam optimizer (dynamically adjusts learning speed)\n# 'binary_crossentropy' = the standard loss function (error calculator) for yes/no predictions\nmodel_binary.compile(optimizer=Adam(learning_rate=1e-4), loss='binary_crossentropy', metrics=['accuracy'])\n\n# Callbacks : automated assistants during training\n# early_stopping: stops training if the validation error ('val_loss') doesn't improve for 4 epochs\nearly_stopping = EarlyStopping(monitor='val_loss', patience=4, restore_best_weights=True)\n# reduce_lr: halves the learning rate if the AI stops improving, allowing for finer adjustments\nreduce_lr = ReduceLROnPlateau(monitor='val_loss', factor=0.5, patience=2, min_lr=1e-6, verbose=1)\n\nprint(\"Start of training of phase 1\")\n\n# Train the model (fit) using the batches of images generated earlier\nhistory_binary = model_binary.fit(\n    train_generator,\n    epochs=10, # Maximum number of training loops over the entire dataset\n    validation_data=test_generator, # Evaluate performance on unseen data after every epoch\n    callbacks=[early_stopping, reduce_lr] # Plug in the automated assistants\n)\nprint(\"Phase 1 training complete\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-20T20:06:04.293627Z","iopub.execute_input":"2026-04-20T20:06:04.294466Z","iopub.status.idle":"2026-04-20T20:21:46.003819Z","shell.execute_reply.started":"2026-04-20T20:06:04.294434Z","shell.execute_reply":"2026-04-20T20:21:46.002973Z"}},"outputs":[{"name":"stdout","text":"Building of the Binary Classification Model\n","output_type":"stream"},{"name":"stderr","text":"I0000 00:00:1776715566.029776      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:0 with 13757 MB memory:  -> device: 0, name: Tesla T4, pci bus id: 0000:00:04.0, compute capability: 7.5\nI0000 00:00:1776715566.035995      55 gpu_device.cc:2019] Created device /job:localhost/replica:0/task:0/device:GPU:1 with 13757 MB memory:  -> device: 1, name: Tesla T4, pci bus id: 0000:00:05.0, compute capability: 7.5\n","output_type":"stream"},{"name":"stdout","text":"Downloading data from https://storage.googleapis.com/keras-applications/efficientnetb0_notop.h5\n\u001b[1m16705208/16705208\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 0us/step\nStart of training of phase 1\nEpoch 1/10\n","output_type":"stream"},{"name":"stderr","text":"WARNING: All log messages before absl::InitializeLog() is called are written to STDERR\nI0000 00:00:1776715581.222035     340 servi